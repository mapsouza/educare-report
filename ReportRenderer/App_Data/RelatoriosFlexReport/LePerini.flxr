    <Layout />
    <DataSources>
      <DataSource>
        <Name>Main</Name>
        <DataProvider>OLEDB</DataProvider>
        <ConnectionString>Provider=SQLOLEDB;Password=sint;Persist Security Info=True;User ID=saDBA;Initial Catalog=LePerini;Data Source=leperini.pdsinformatica.com.br,2000</ConnectionString>
        <RecordSource>SELECT
Avg(Not11) Not11, Avg(Not12) Not12, Avg(Med1) Med1,
Avg(Not21) Not21, Avg(Not22) Not22, Avg(Med2) Med2,
Avg(Not31) Not31, Avg(Not32) Not32, Avg(Med3) Med3
FROM qNotasOrdem WHERE ChaveTurma = Parameter0 AND CodiMat = Parameter1 </RecordSource>
