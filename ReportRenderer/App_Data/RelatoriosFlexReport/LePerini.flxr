        <Type>Detail</Type>
        <OnPrint>If IsNumeric(Med1) Then
  Nota1Tri = "S"
EndIf
If IsNumeric(Med2) Then
  Nota2Tri = "S"
EndIf
If IsNumeric(Med3) Then
  Nota3Tri = "S"
EndIf
If cClas1 = "*" Then
  cClas3Tri = "*" 
EndIf

If cClas2 = "*" Then
  cClasRecup = "*"
EndIf


if Nota3Tri = "S" Then
  if fldMed3.Text = "NF" Then
    fldFreq1.Text = "-"
    fldCarga1.Text = "-"
  Else
    fldFreq1.Text = IIf(Isnull(Freq),"100,00",Freq)
    fldCarga1.Text = Carga
  endif
  Exit
EndIf

if Nota2Tri = "S" Then
  if fldMed2.Text = "NF" Then
    fldFreq1.Text = "-"
    fldCarga1.Text = "-"
  Else
    fldFreq1.Text = IIf(Isnull(Freq),"100,00",Freq)
    fldCarga1.Text = Carga
  endif
  Exit
EndIf

if Nota1Tri = "S" Then
  if fldMed1.Text = "NF" Then
    fldFreq1.Text = "-"
    fldCarga1.Text = "-"
  Else
    fldFreq1.Text = IIf(Isnull(Freq),"100,00",Freq)
    fldCarga1.Text = Carga
  endif
  Exit
EndIf

</OnPrint>
