        <ConnectionString>Provider=SQLOLEDB;Password=sint;Persist Security Info=True;User ID=saDBA;Initial Catalog=LePerini;Data Source=leperini.pdsinformatica.com.br,2000</ConnectionString>
        <RecordSource>SELECT Anolet,Periodo,DescPeriodo,Curso,DescCurso,Serie,DescSerie,Turma,nClasse,NomeAlu,CodiProf,NomeProf,CodiMat,Nome,Abrev,dbo.BuscaConceito(NOT21,Anolet,Curso,Serie,Codimat,'0.00', 0) AS PC,dbo.BuscaConceito(NOT22,Anolet,Curso,Serie,Codimat,'0.00', 0) AS PO,dbo.BuscaConceito(NOT23,Anolet,Curso,Serie,Codimat,'0.00', 0) AS AT,CASE WHEN Disp2=1 THEN 'NF' ELSE dbo.BuscaConceito(NOT2,Anolet,Curso,Serie,Codimat,'0.0', 0 ) END AS MP,dbo.BuscaConceito(NOT2R,Anolet,Curso,Serie,Codimat,'0.00', 0) AS NR,CASE WHEN Disp2=1 THEN 'NF' ELSE dbo.BuscaConceito(MED2,Anolet,Curso,Serie,Codimat,'0.0',0) END AS MF,ChaveTurma, Codstatus,OrdemCurso FROM qNotasOrdem WHERE ChaveTurma = '2023NM1 5B' AND CodiMat = 3 ORDER BY Anolet,Periodo,OrdemCurso,Turma,Nome,nClasse</RecordSource>
      </DataSource>
    </DataSources>
