        <ConnectionString>Provider=SQLOLEDB;Password=sint;Persist Security Info=True;User ID=educare;Initial Catalog=LePerini;Data Source=leperini.pdsinformatica.com.br</ConnectionString>
        <RecordSource>SELECT * FROM qAulas where AulaData Between '24/05/2023' AND '31/05/2023' AND Curso = 'I' And Serie = 5 AND Turma = 'A' ORDER BY AulaData,Anolet,Curso,Serie,Turma,Ordem,NomeProf</RecordSource>
      </DataSource>
    </DataSources>
    <ReportParameters>
      <ReportParameter>
        <Name>Parameter0</Name>
        <Values>
          <Item sys="string">True</Item>
        </Values>
        <Nullable>true</Nullable>
        <AllowBlank>true</AllowBlank>
        <MultiValue>true</MultiValue>
        <Hidden>true</Hidden>
        <AllowedValuesDefinition>
          <Values />
        </AllowedValuesDefinition>
      </ReportParameter>
      <ReportParameter>
        <Name>Titulo</Name>
        <Nullable>true</Nullable>
        <AllowBlank>true</AllowBlank>
        <Hidden>true</Hidden>
        <AllowedValuesDefinition>
          <Values />
