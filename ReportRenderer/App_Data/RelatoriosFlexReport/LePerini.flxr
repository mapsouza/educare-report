        <RecordSource>select Anolet,Periodo,DescPeriodo,Curso,DescCurso,Serie,DescSerie,Turma,nClasse,NomeAlu,
CodiMat,Nome,Abrev,
NOT11 AS PC,
NOT12 AS PO,
NOT13 AS AT,
NOT1 AS MP,
NOT1R AS NR,
MED1 AS MF,CHAVETURMA,CODSTATUS,OrdemCurso FROM qNotasOrdem WHERE Anolet = 2017 and curso = '1' and serie = 5
ORDER BY Anolet,Periodo,OrdemCurso,Turma,Nome,nClasse</RecordSource>
