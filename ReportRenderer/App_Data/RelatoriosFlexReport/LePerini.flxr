        </Font>
        <Text>
          <Expression>"ATA DE RESULTADOS FINAIS - ANO LETIVO: " &amp; Anolet</Expression>
        </Text>
      </TextField>
      <TextField>
        <Name>titleLbl3</Name>
        <Section>PageHeader</Section>
        <SubSectionIndex>1</SubSectionIndex>
        <Left>0</Left>
        <Top>280</Top>
        <Width>15675</Width>
        <Height>280</Height>
        <Align>CenterMiddle</Align>
        <Font>
          <Name>Calibri</Name>
          <Size>12</Size>
          <Bold>true</Bold>
        </Font>
        <Text>
          <Expression>NomeOficial &amp; " - " &amp; DescSerie &amp; " " &amp; Turma</Expression>
        </Text>
      </TextField>
      <ParagraphField>
        <Name>Field2</Name>
        <Section>PageHeader</Section>
        <SubSectionIndex>1</SubSectionIndex>
        <Left>0</Left>
        <Top>560</Top>
        <Width>15675</Width>
        <Height>450</Height>
        <Align>JustTop</Align>
        <Font>
          <Name>Arial</Name>
          <Size>9</Size>
        </Font>
        <Content>
          <ParagraphText>
            <Text>
              <Value sys="string">                   Aos </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Text>
              <Expression>Format(Day(Parameter0.Value(4)),"00") &amp; Iif(Parameter0.Value(4)&gt;1," dias"," dia")</Expression>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Text>
              <Value sys="string"> do mês de </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Text>
              <Expression>MonthName(Month(Parameter0.Value(4)))</Expression>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Text>
              <Value sys="string"> de </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Text>
              <Expression>Year(Parameter0.Value(4))</Expression>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Text>
              <Value sys="string"> concluiu-se o processo dos resultados finais dos alunos matriculados em </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Text>
              <Expression>Anolet</Expression>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Text>
              <Value sys="string">, no ENSINO FUNDAMENTAL - </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Text>
              <Expression>DescSerie</Expression>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Text>
              <Value sys="string">, turma </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Text>
              <Expression>Turma</Expression>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Text>
              <Value sys="string">, período </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Text>
              <Expression>DescPeriodo</Expression>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Text>
              <Value sys="string"> deste estabelecimento, com os seguintes resultados:</Value>
            </Text>
          </ParagraphText>
        </Content>
      </ParagraphField>
