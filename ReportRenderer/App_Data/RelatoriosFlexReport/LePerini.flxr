    <DataSources>
      <DataSource>
        <Name>Main</Name>
        <DataProvider>OLEDB</DataProvider>
        <ConnectionString>Provider=SQLOLEDB;Password=sint;Persist Security Info=True;User ID=educare;Initial Catalog=LePerini;Data Source=leperini.pdsinformatica.com.br,2000</ConnectionString>
        <RecordSource>SELECT  qFichaInd.CodiMatricula,NomeOficial,DescSerie,DescPeriodo,dbo.FreqGeral(qFichaInd.CODIMATRICULA) As FreqGeral, CodStatus,Sit4Bim,SitRecup, qFichaInd.CodiAlu,qFichaInd.Anolet,periodo,Curso,Serie, Turma, nClasse,dbo.ProperCase(qFichaInd.NomeAlu) As NomeAlu,RAAlu, Max(CodStatus) As CodStatus, 
(CASE WHEN Max(Sit4Bim) = 'RC' THEN Max(SitRecup+cClas2) ELSE Max(Sit4Bim+cClas1) END) As Sit,
MAX(CASE WHEN qFichaInd.Abrev = 'ARTE' THEN (CASE WHEN Recup IS NOT NULL Then MediaF ELSE Media END) ELSE '-' END) AS [ARTE], 
MAX(CASE WHEN qFichaInd.Abrev = 'C. APL. COTID.' THEN (CASE WHEN Recup IS NOT NULL Then MediaF ELSE Media END) ELSE '-' END) AS [C. APL. COTID.], 
MAX(CASE WHEN qFichaInd.Abrev = 'CIENCIAS' THEN (CASE WHEN Recup IS NOT NULL Then MediaF ELSE Media END) ELSE '-' END) AS [CIENCIAS], 
MAX(CASE WHEN qFichaInd.Abrev = 'ED. FISICA' THEN (CASE WHEN Recup IS NOT NULL Then MediaF ELSE Media END) ELSE '-' END) AS [ED. FISICA], 
MAX(CASE WHEN qFichaInd.Abrev = 'ESP CULT.' THEN (CASE WHEN Recup IS NOT NULL Then MediaF ELSE Media END) ELSE '-' END) AS [ESP CULT.], 
MAX(CASE WHEN qFichaInd.Abrev = 'FILOSOFIA' THEN (CASE WHEN Recup IS NOT NULL Then MediaF ELSE Media END) ELSE '-' END) AS [FILOSOFIA], 
MAX(CASE WHEN qFichaInd.Abrev = 'GEOGRAFIA' THEN (CASE WHEN Recup IS NOT NULL Then MediaF ELSE Media END) ELSE '-' END) AS [GEOGRAFIA], 
MAX(CASE WHEN qFichaInd.Abrev = 'HISTORIA' THEN (CASE WHEN Recup IS NOT NULL Then MediaF ELSE Media END) ELSE '-' END) AS [HISTORIA], 
MAX(CASE WHEN qFichaInd.Abrev = 'INT.EMOC.' THEN (CASE WHEN Recup IS NOT NULL Then MediaF ELSE Media END) ELSE '-' END) AS [INT.EMOC.], 
MAX(CASE WHEN qFichaInd.Abrev = 'L. PORT.' THEN (CASE WHEN Recup IS NOT NULL Then MediaF ELSE Media END) ELSE '-' END) AS [L. PORT.], 
MAX(CASE WHEN qFichaInd.Abrev = 'LT.PROD.TEX.' THEN (CASE WHEN Recup IS NOT NULL Then MediaF ELSE Media END) ELSE '-' END) AS [LT.PROD.TEX.], 
MAX(CASE WHEN qFichaInd.Abrev = 'MAT-ED.FIN.' THEN (CASE WHEN Recup IS NOT NULL Then MediaF ELSE Media END) ELSE '-' END) AS [MAT. ED.FIN.], 
MAX(CASE WHEN qFichaInd.Abrev = 'MATEMATICA' THEN (CASE WHEN Recup IS NOT NULL Then MediaF ELSE Media END) ELSE '-' END) AS [MATEMATICA], 
MAX(CASE WHEN qFichaInd.Abrev = 'MUSICA' THEN (CASE WHEN Recup IS NOT NULL Then MediaF ELSE Media END) ELSE '-' END) AS [MUSICA], 
MAX(CASE WHEN qFichaInd.Abrev = 'PROG BIL ING' THEN (CASE WHEN Recup IS NOT NULL Then MediaF ELSE Media END) ELSE '-' END) AS [PROG BIL ING], 
MAX(CASE WHEN qFichaInd.Abrev = 'ROBOTICA' THEN (CASE WHEN Recup IS NOT NULL Then MediaF ELSE Media END) ELSE '-' END) AS [ROBOTICA] From qFichaInd 
WHERE Anolet = 2025 And Curso = '1' And CodStatus &lt;=10
GROUP BY  qFichaInd.CodiMatricula,CodStatus,Sit4Bim,SitRecup,qFichaInd.CodiAlu, qFichaInd.Anolet, Periodo,DescPeriodo,Curso,NomeOficial, Serie,DescSerie, Turma, nClasse,dbo.ProperCase( NomeAlu), RAAlu ORDER BY  Anolet, Curso, Serie, Turma, NClasse
</RecordSource>
      </DataSource>
    </DataSources>
