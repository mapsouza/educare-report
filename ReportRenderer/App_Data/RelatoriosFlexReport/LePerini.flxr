        <RecordSource>SELECT (SELECT dbo.ProperCase(Nome)) As NomeOk,* FROM qFichaInd Where Anolet = 2024 and curso = '1' and serie in (2,3,4,5) and turma = 'A' and nclasse = 1</RecordSource>
