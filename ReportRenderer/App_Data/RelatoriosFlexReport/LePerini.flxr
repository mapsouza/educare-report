Max(CASE WHEN SERIE = '4' THEN Estado ELSE '-' END) AS Estado4,

Max(CASE WHEN SERIE = '5' THEN Anolet ELSE '-' END) AS AnoLet5,
Max(CASE WHEN SERIE = '5' THEN DescSeriE else '5º Ano' end) AS DescSerie5,
Max(CASE WHEN SERIE = '5' THEN Nome ELSE '-' END) AS EscolaNome5,
Max(CASE WHEN SERIE = '5' THEN Cidade ELSE '-' END) AS Cidade5,
Max(CASE WHEN SERIE = '5' THEN Estado ELSE '-' END) AS Estado5,

Max(CASE WHEN SERIE = '6' THEN Anolet ELSE '-' END) AS AnoLet6,
Max(CASE WHEN SERIE = '6' THEN DescSeriE else '6º Ano' end) AS DescSerie6,
Max(CASE WHEN SERIE = '6' THEN Nome ELSE '-' END) AS EscolaNome6,
