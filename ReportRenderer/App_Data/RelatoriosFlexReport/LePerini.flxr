  <Report ref="1">
    <Name>rptRelAval2025</Name>
    <DataSourceName>Main</DataSourceName>
    <ReportInfo>
      <Author>Marcel</Author>
    </ReportInfo>
    <Layout>
      <Width>10740</Width>
      <Margin>561.6</Margin>
      <MarginTop>561.6</MarginTop>
      <MarginRight>561.6</MarginRight>
      <MarginBottom>561.6</MarginBottom>
      <Orientation>Portrait</Orientation>
      <PaperSize>A4</PaperSize>
    </Layout>
    <Font>
      <Name>Calibri</Name>
      <Size>11</Size>
    </Font>
    <DataSources>
      <DataSource>
        <Name>Main</Name>
        <DataProvider>OLEDB</DataProvider>
        <ConnectionString>Provider=SQLOLEDB;Password=ProfOld123W0;Persist Security Info=True;User ID=SIProfessor;Initial Catalog=LePerini;Data Source=leperini.pdsinformatica.com.br</ConnectionString>
        <RecordSource>SELECT CodiMatricula,CodiAlu,NomeAlu,Anolet,TipoCur,Periodo,DescPeriodo,Curso,DescCurso,NomeOficial,Serie,DescSerie,Turma,nClasse,
CodStatus,CodiMat,DescMat,Ordem,Descricao, CodRelAvalConceito, ChaveTurma,OrdemCurso,RaAlu,RaEst, DtNascAlu, 
(SELECT TOP 1 NomeProf FROM qMatprofprof where qMatProfProf.Anolet = qRelAvalAlunos.Anolet AND 
qMatProfProf.Curso = qRelAvalAlunos.Curso AND qMatProfProf.Serie = qRelAvalAlunos.Serie AND 
qMatProfProf.Turma = qRelAvalAlunos.Turma AND qMatProfProf.CodiMat = qRelAvalAlunos.CodiMat) As NomeProf, 
MAX(CASE WHEN Bimestre='1' THEN Conceito1 ELSE NULL END) AS 'Conceito1', 
MAX(CASE WHEN Bimestre='1' THEN ConceitoValor ELSE NULL END) AS 'ConceitoValor1', 
MAX(CASE WHEN Bimestre='2' THEN Conceito1 ELSE NULL END) AS 'Conceito2', 
MAX(CASE WHEN Bimestre='2' THEN ConceitoValor ELSE NULL END) AS 'ConceitoValor2', 
MAX(CASE WHEN Bimestre='3' THEN Conceito1 ELSE NULL END) AS 'Conceito3',
MAX(CASE WHEN Bimestre='3' THEN ConceitoValor ELSE NULL END) AS 'ConceitoValor3',
(SELECT AVG(ConceitoValor) FROM qRelAvalAlunos RelMedia WHERE RelMedia.Curso = qRelAvalAlunos.Curso AND RelMedia.Serie = qRelAvalAlunos.Serie AND RelMedia.Turma = qRelAvalAlunos.Turma AND RelMedia.CodiMat = qRelAvalAlunos.CodiMat And RelMedia.Descricao = qRelAvalAlunos.Descricao And RelMedia.Bimestre=2) Media
FROM qRelAvalAlunos  Where ChaveTurma IN ('2025NV1 5C') 
GROUP BY CodiMatricula,CodiAlu,NomeAlu,Anolet,TipoCur,Periodo,DescPeriodo,Curso,DescCurso,NomeOficial,Serie,DescSerie,Turma,
nClasse, CodStatus , CodiMat, DescMat, Ordem, Descricao, CodRelAvalConceito,   
ChaveTurma, OrdemCurso, RaAlu, RaEst, DtNascAlu 
ORDER BY Anolet,Periodo,Curso,Serie,Turma,nClasse,Ordem 
</RecordSource>
      </DataSource>
    </DataSources>
    <ReportParameters>
      <ReportParameter>
        <Name>Parameter0</Name>
        <Values>
          <Item sys="string">2º Trimestre</Item>
          <Item sys="string">25/04/2019</Item>
          <Item sys="string" />
          <Item sys="string">RG: 3.566.199 SC</Item>
        </Values>
        <Nullable>true</Nullable>
        <AllowBlank>true</AllowBlank>
        <MultiValue>true</MultiValue>
        <Hidden>true</Hidden>
        <AllowedValuesDefinition>
          <Values />
        </AllowedValuesDefinition>
      </ReportParameter>
      <ReportParameter>
        <Name>Titulo</Name>
        <Value sys="string">Avaliação Descritiva</Value>
        <AllowBlank>true</AllowBlank>
        <Hidden>true</Hidden>
        <AllowedValuesDefinition>
          <Values />
        </AllowedValuesDefinition>
      </ReportParameter>
    </ReportParameters>
    <Groups>
      <Group>
        <Name>DescCurso</Name>
        <GroupBy>DescCurso</GroupBy>
        <KeepTogether>KeepFirstDetail</KeepTogether>
        <OutlineLabel>
          <Expression>DescCurso</Expression>
        </OutlineLabel>
      </Group>
      <Group>
        <Name>DescSerie</Name>
        <GroupBy>DescSerie</GroupBy>
        <KeepTogether>KeepFirstDetail</KeepTogether>
        <OutlineLabel>
          <Expression>DescSerie</Expression>
        </OutlineLabel>
      </Group>
      <Group>
        <Name>Turma</Name>
        <GroupBy>Turma</GroupBy>
        <KeepTogether>KeepFirstDetail</KeepTogether>
        <OutlineLabel>
          <Expression>Turma</Expression>
        </OutlineLabel>
      </Group>
      <Group>
        <Name>CodiMatricula</Name>
        <GroupBy>CodiMatricula</GroupBy>
      </Group>
      <Group>
        <Name>NomeAlu</Name>
        <GroupBy>NomeAlu</GroupBy>
        <KeepTogether>KeepFirstDetail</KeepTogether>
        <OutlineLabel>
          <Expression>NomeAlu</Expression>
        </OutlineLabel>
      </Group>
      <Group>
        <Name>DescMat</Name>
        <GroupBy>DescMat</GroupBy>
        <KeepTogether>KeepFirstDetail</KeepTogether>
        <OutlineLabel>
          <Expression>DescMat</Expression>
        </OutlineLabel>
      </Group>
    </Groups>
    <Sections>
      <Section>
        <Name>Detail</Name>
        <Background type="Solid">
          <Color>FFFFFFFF</Color>
        </Background>
        <SubSections>
          <SubSection>
            <SplitBehavior>Never</SplitBehavior>
            <Height>280</Height>
          </SubSection>
        </SubSections>
        <Type>Detail</Type>
        <SplitBehavior>Never</SplitBehavior>
        <OnFormat>iF Parameter0.Value(0) = "1º Semestre" Then
  Conceito1Ctl1.Text = ""
  
EndIf
If Media &gt;= 5 Then
  Conceito1Ctl3.Text = "AC"
ElseIf Media &gt;= 2.6 And Media &lt;= 4.9 Then
  Conceito1Ctl3.Text = "DE"
ElseIf Media &gt;= 0.1 And Media &lt;= 2.5 Then
  Conceito1Ctl3.Text = "ABE"
Else
  Conceito1Ctl3.Text = "NA"
EndIf</OnFormat>
      </Section>
      <Section>
        <Name>Header</Name>
        <Background type="Solid">
          <Color>FFFFFFFF</Color>
        </Background>
        <SubSections>
          <SubSection>
            <Height>840</Height>
          </SubSection>
        </SubSections>
        <Type>Header</Type>
      </Section>
      <Section>
        <Name>Footer</Name>
        <SubSections>
          <SubSection>
            <SplitBehavior>SplitIfNeeded</SplitBehavior>
            <Visible>false</Visible>
            <AutoHeight>GrowAndShrink</AutoHeight>
          </SubSection>
        </SubSections>
        <Type>Footer</Type>
        <SplitBehavior>SplitIfNeeded</SplitBehavior>
        <Visible>false</Visible>
      </Section>
      <Section>
        <Name>PageHeader</Name>
        <Background type="Solid">
          <Color>FFFFFFFF</Color>
        </Background>
        <SubSections>
          <SubSection>
            <Height>510</Height>
          </SubSection>
