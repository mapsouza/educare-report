        <ConnectionString>Provider=SQLOLEDB.1;Password=sint;Persist Security Info=True;User ID=educare;Initial Catalog=Leperini;Data Source=leperini.pdsinformatica.com.br</ConnectionString>
        <RecordSource>SELECT 
Max(CASE WHEN SERIE = '1' THEN Anolet ELSE '-' END) AS AnoLet1,
Max(CASE WHEN SERIE = '2' THEN Anolet ELSE '-' END) AS AnoLet2,
Max(CASE WHEN SERIE = '3' THEN Anolet ELSE '-' END) AS AnoLet3,
Max(CASE WHEN SERIE = '4' THEN Anolet ELSE '-' END) AS AnoLet4,
Max(CASE WHEN SERIE = '5' THEN Anolet ELSE '-' END) AS AnoLet5,
Max(CASE WHEN SERIE = '6' THEN Anolet ELSE '-' END) AS AnoLet6,
Max(CASE WHEN SERIE = '7' THEN Anolet ELSE '-' END) AS AnoLet7,
Max(CASE WHEN SERIE = '8' THEN Anolet ELSE '-' END) AS AnoLet8,
Max(CASE WHEN SERIE = '9' THEN Anolet ELSE '-' END) AS AnoLet9
From qHistorico WHERE Codhist = Parameter0 AND Curso = '1'</RecordSource>
      </DataSource>
