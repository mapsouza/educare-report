          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Value sys="string">
</Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
            </Font>
            <Text>
              <Value sys="string">ALUNO(A):</Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Value sys="string"> </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
              <Underline>true</Underline>
            </Font>
            <Text>
              <Expression>=NomeAlu</Expression>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Value sys="string"> matriculado para o (a) </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
              <Underline>true</Underline>
            </Font>
            <Text>
              <Expression>=NomeOficial</Expression>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
              <Underline>true</Underline>
            </Font>
            <Text>
              <Value sys="string"> do curso </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
              <Underline>true</Underline>
            </Font>
            <Text>
              <Expression>=DescSerie &amp; " - " &amp; Turma</Expression>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
            </Font>
            <Text>
              <Value sys="string">,</Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Value sys="string"> no período </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
              <Underline>true</Underline>
            </Font>
            <Text>
              <Expression>=DescPeriodo</Expression>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
              <Underline>true</Underline>
            </Font>
            <Text>
              <Value sys="string">
</Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Text>
              <Value sys="string">
</Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Value sys="string">Considerando que as partes firmaram um contrato de prestação de serviços educacionais no ano letivo 2025, vem aditar o referido Contrato, nos termos abaixo:

</Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
            </Font>
            <Text>
              <Value sys="string">Cláusula 1ª - Do Objeto

</Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Value sys="string">1.1	O objeto do presente Adendo Contratual é a prestação de serviços </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
            </Font>
            <Text>
              <Value sys="string">adicionais </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Value sys="string">àqueles contratados por meio do </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
            </Font>
            <Text>
              <Value sys="string">CONTRATO DE PRESTAÇÃO DE SERVIÇOS EDUCACIONAIS (contrato principal)</Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Value sys="string">, a seguir descritos, em período suplementar à carga horária dos serviços educacionais pertinentes àquele contrato, conforme opção do/a (s) </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
            </Font>
            <Text>
              <Value sys="string">CONTRATANTES:</Value>
            </Text>
          </ParagraphText>
        </Content>
      </ParagraphField>
      <ParagraphField>
        <Name>Field3</Name>
        <Section>Detail</Section>
        <Left>165</Left>
        <Top>12945</Top>
        <Width>10470</Width>
        <Height>4185</Height>
        <AutoHeight>CanGrow</AutoHeight>
        <Align>JustTop</Align>
        <Font>
          <Name>Arial</Name>
          <Size>9</Size>
        </Font>
        <Content>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
            </Font>
            <Text>
              <Value sys="string">Parágrafo Único </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Value sys="string">- Saídas para atividades externas, passeios, visitas e outras atividades que dependam de transporte ou ingressos, os mesmos correrão por conta da </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
            </Font>
            <Text>
              <Value sys="string">CONTRATANTE.

1.2 </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Value sys="string">As atividades serão realizadas em salas específicas ou locais que a </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
            </Font>
            <Text>
              <Value sys="string">CONTRATADA</Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Value sys="string"> indicar, tendo em vista a natureza do conteúdo e a técnica necessária para exigir êxito na programação.
</Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
            </Font>
            <Text>
              <Value sys="string">1.3</Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Value sys="string"> São de inteira responsabilidade da</Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
            </Font>
            <Text>
              <Value sys="string"> CONTRATADA </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Value sys="string">o planejamento e a prestação dos serviços constantes na Cláusula 1ª, no que se refere a datas, locais, designação de professores e monitores, metodologia, locais de atividades externas, organização de classes e agrupamento de alunos, além de outras providências que as referidas atividades exigirem, obedecendo ao exclusivo critério da </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
            </Font>
            <Text>
              <Value sys="string">CONTRATADA, </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Value sys="string">sem ingerência do (a) </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
            </Font>
            <Text>
              <Value sys="string">CONTRATANTE.
1.4 </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Value sys="string">Após a adesão e escolha dos dias a serem frequentados, </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
            </Font>
            <Text>
              <Value sys="string">NÃO </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Value sys="string">será aceito trocas ou compensação dos dias devido a faltas ou outras demandas.
</Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
            </Font>
            <Text>
              <Value sys="string">
Cláusula 2ª - Do Pagamento

2.1 </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Value sys="string">Como contrapartida pelos serviços que serão prestados de janeiro a dezembro de 2025, conforme previsto na Cláusula 1ª, o (a) </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
            </Font>
            <Text>
              <Value sys="string">CONTRATANTE </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Value sys="string">pagará à </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
            </Font>
            <Text>
              <Value sys="string">CONTRATADA, </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Value sys="string">parcelas mensais com vencimento no </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
            </Font>
            <Text>
              <Value sys="string">dia 03</Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Value sys="string"> de cada mês referente a seguinte opção escolhida:
         </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Expression>iif(VlParcela*NoParc=Anuidade,NoParc +  " parcelas de R$ " + Format(VlParcela,"Standard") ,iif(VlParcela &lt;&gt; Anuidade,"( X ) Uma parcela de R$ " + Format(Anuidade - (NoParc * VlParcela), "Standard") + " + " + NoParc +  " parcelas de R$ " + VlParcela ,"(  x  ) à vista no valor de " + Anuidade))</Expression>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Value sys="string">, </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Expression>Iif(noparc &gt; 1,"sendo a 1ª no ato da matrícula e as demais sucessivamente.","sendo pago no ato da matrícula.")</Expression>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Value sys="string">
</Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Text>
              <Value sys="string">
</Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
            </Font>
            <Text>
              <Value sys="string">Não realizamos compensação de dias por faltas ou outros		</Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Text>
              <Value sys="string">
</Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Value sys="string">
</Value>
            </Text>
