  <Report ref="1">
    <Name>rptRelAvalEIBim</Name>
    <DataSourceName>Main</DataSourceName>
    <ReportInfo>
      <Author>Marcel</Author>
    </ReportInfo>
    <Layout>
      <Width>10770</Width>
      <Margin>561.6</Margin>
      <MarginTop>561.6</MarginTop>
      <MarginRight>561.6</MarginRight>
      <MarginBottom>561.6</MarginBottom>
      <Orientation>Portrait</Orientation>
      <PaperSize>A4</PaperSize>
    </Layout>
    <Font>
      <Name>Calibri</Name>
      <Size>11</Size>
    </Font>
    <DataSources>
      <DataSource>
        <Name>Main</Name>
        <DataProvider>OLEDB</DataProvider>
        <ConnectionString>Provider=SQLOLEDB;Password=sint;Persist Security Info=True;User ID=educare;Initial Catalog=LePerini;Data Source=leperini.pdsinformatica.com.br</ConnectionString>
        <RecordSource>SELECT CodiMatricula,CodiAlu,NomeAlu,Anolet,TipoCur,Periodo,DescPeriodo,Curso,DescCurso,Serie,DescSerie,Turma,nClasse,
CodStatus,CodiMat,DescMat,Ordem,Descricao, CodRelAvalConceito, ChaveTurma,OrdemCurso,RaAlu,RaEst, DtNascAlu, 
(SELECT TOP 1 NomeProf FROM qMatprofprof where qMatProfProf.Anolet = qRelAvalAlunos.Anolet AND 
qMatProfProf.Curso = qRelAvalAlunos.Curso AND qMatProfProf.Serie = qRelAvalAlunos.Serie AND 
qMatProfProf.Turma = qRelAvalAlunos.Turma AND qMatProfProf.CodiMat = qRelAvalAlunos.CodiMat AND qMatProfProf.Codiprof &lt;&gt; 53) As NomeProf, 
MAX(CASE WHEN Bimestre='1' THEN Conceito1 ELSE NULL END) AS 'Conceito1', 
MAX(CASE WHEN Bimestre='2' THEN Conceito1 ELSE NULL END) AS 'Conceito2', 
MAX(CASE WHEN Bimestre='3' THEN Conceito1 ELSE NULL END) AS 'Conceito3', 
MAX(CASE WHEN Bimestre='4' THEN Conceito1 ELSE NULL END) AS 'Conceito4'
FROM qRelAvalAlunos  Where ChaveTurma IN ('2023NVI 4D') AND nClasse In (8,15)
GROUP BY CodiMatricula,CodiAlu,NomeAlu,Anolet,TipoCur,Periodo,DescPeriodo,Curso,DescCurso,Serie,DescSerie,Turma,
nClasse, CodStatus , CodiMat, DescMat, Ordem, Descricao, CodRelAvalConceito,   
ChaveTurma, OrdemCurso, RaAlu, RaEst, DtNascAlu 
ORDER BY Anolet,Periodo,Curso,Serie,Turma,nClasse,Ordem 
</RecordSource>
      </DataSource>
    </DataSources>
    <ReportParameters>
      <ReportParameter>
        <Name>Parameter0</Name>
        <Values>
          <Item sys="string">2º Semestre</Item>
          <Item sys="string">25/04/2019</Item>
          <Item sys="string">Tatiana dos Santos</Item>
          <Item sys="string">RG: 3.566.199 SC</Item>
        </Values>
        <Nullable>true</Nullable>
        <AllowBlank>true</AllowBlank>
        <MultiValue>true</MultiValue>
        <Hidden>true</Hidden>
        <AllowedValuesDefinition>
          <Values />
        </AllowedValuesDefinition>
      </ReportParameter>
      <ReportParameter>
