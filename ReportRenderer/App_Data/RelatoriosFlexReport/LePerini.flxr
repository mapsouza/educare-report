        <RecordSource>SELECT 
Max(CASE WHEN SERIE = '1' THEN Anolet ELSE '-' END) AS AnoLet1,
Max(CASE WHEN SERIE = '1' THEN DescSeriE else '1º Ano' end) AS DescSerie1,
Max(CASE WHEN SERIE = '1' THEN Nome ELSE '-' END) AS EscolaNome1,
Max(CASE WHEN SERIE = '1' THEN Cidade ELSE '-' END) AS Cidade1,
Max(CASE WHEN SERIE = '1' THEN Estado ELSE '-' END) AS Estado1,

