    <Fields>
      <ParagraphField>
        <Name>Field1</Name>
        <Section>Detail</Section>
        <Left>0</Left>
        <Top>120</Top>
        <Width>10635</Width>
        <Height>4695</Height>
        <AutoHeight>CanGrow</AutoHeight>
        <Align>JustTop</Align>
        <Font>
          <Name>Arial</Name>
          <Size>9</Size>
        </Font>
        <Content>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
            </Font>
            <Text>
              <Value sys="string">I - CONTRATADO: COLÉGIO LE PERINI</Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Value sys="string">, devidamente inscrito no CNPJ/MF sob o nº 28.789.060/0001-54, estabelecido na Rua Armando Sales de Oliveira, nº 623 - Pq São Tomaz de Aquino, nessa cidade de Indaiatuba/SP, doravante denominada, simplesmente </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
            </Font>
            <Text>
              <Value sys="string">"COLÉGIO"</Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Value sys="string">, neste ato representado pela proprietária legal.

</Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
            </Font>
            <Text>
              <Value sys="string">II - CONTRATANTE (S):</Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Value sys="string"> É (são) considerado(s) </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
            </Font>
            <Text>
              <Value sys="string">CONTRATANTE(S)</Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Value sys="string"> o(s) </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
            </Font>
            <Text>
              <Value sys="string">RESPONSÁVEL(EIS) LEGAL(AIS)</Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Value sys="string"> e o </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
            </Font>
            <Text>
              <Value sys="string">RESPONSÁVEL FINANCEIRO</Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Value sys="string"> abaixo indicado(s), já qualificado/a(s) no contrato principal e que assina(m) o presente instrumento.

</Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
            </Font>
            <Text>
              <Value sys="string">1. RESPONSÁVEL LEGAL </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Value sys="string">Sr(a). </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Underline>true</Underline>
            </Font>
            <Text>
              <Expression>=RespFinanc</Expression>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Value sys="string">, portador do RG. nº </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Underline>true</Underline>
            </Font>
            <Text>
              <Expression>=RgResp</Expression>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Value sys="string"> e inscrito no CPF sob o nº </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Underline>true</Underline>
            </Font>
            <Text>
              <Expression>=Format(CpfResp,"@@@.@@@.@@@-@@")</Expression>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Value sys="string"> residente e domiciliado na </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Expression>=EndCob</Expression>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Value sys="string">, na cidade de </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Expression>=CidCob</Expression>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Text>
              <Value sys="string">
</Value>
