      </TextField>
      <ParagraphField>
        <Name>Field2</Name>
        <Section>GroupHeader1</Section>
        <Left>0</Left>
        <Top>3800</Top>
        <Width>10726</Width>
        <Height>1330</Height>
        <MarginLeft>30</MarginLeft>
        <MarginTop>40</MarginTop>
        <MarginRight>30</MarginRight>
        <Align>JustTop</Align>
        <Font>
          <Name>Arial</Name>
          <Size>10</Size>
        </Font>
        <LineSpacing>150</LineSpacing>
        <Content>
          <ParagraphText>
            <Text>
              <Value sys="string">             DECLARO, nos termos do Inciso VII, artigo 24, da Lei 9.394/96, que o aluno </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
            </Font>
            <Text>
              <Expression>NomeAlu</Expression>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
            </Font>
            <Text>
              <Value sys="string">, </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Text>
              <Value sys="string">R.G. nº </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
            </Font>
            <Text>
              <Expression>RgAlu + "/" + RgEst</Expression>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
            </Font>
            <Text>
              <Value sys="string">, </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Text>
              <Value sys="string">R.A. nº </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
            </Font>
            <Text>
              <Expression>Format(RAAlu,"@@@.@@@.@@@-@") + "/" + RaEst</Expression>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Text>
              <Value sys="string"> encontra-se matriculado no </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
            </Font>
            <Text>
              <Expression>DescSerie + " " + Turma</Expression>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
            </Font>
            <Text>
              <Value sys="string"> </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Text>
              <Value sys="string">do </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Arial</Name>
              <Size>10</Size>
              <Bold>true</Bold>
            </Font>
            <Text>
