  <Report ref="1">
    <Name>rptDiarioAula</Name>
    <DataSourceName>Main</DataSourceName>
    <GlobalScripts>If Parameter0.Value(0) = "True" Then
  Group_AulaData_Footer.ForcePageBreak =  2
EndIf</GlobalScripts>
    <ReportInfo>
