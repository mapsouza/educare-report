  <Report ref="1">
    <Name>rptFichaObsAluno</Name>
    <DataSourceName>Main</DataSourceName>
    <ReportInfo>
      <Author>Marcel</Author>
    </ReportInfo>
    <Layout>
      <Width>10646</Width>
      <Margin>561.6</Margin>
      <MarginTop>561.6</MarginTop>
      <MarginRight>561.6</MarginRight>
      <MarginBottom>561.6</MarginBottom>
      <Orientation>Portrait</Orientation>
      <ColumnLayout>Across</ColumnLayout>
      <PaperSize>A4</PaperSize>
    </Layout>
    <Font>
      <Name>Calibri</Name>
      <Size>11</Size>
    </Font>
    <DataSources>
      <DataSource>
        <Name>Main</Name>
        <DataProvider>OLEDB</DataProvider>
        <ConnectionString>Provider=SQLOLEDB;Password=sint;Persist Security Info=True;User ID=educare;Initial Catalog=LePerini;Data Source=leperini.pdsinformatica.com.br</ConnectionString>
        <RecordSource>
SELECT DISTINCT [CodiMatricula] ,[CodiAlu] ,[NomeAlu] ,[AnoLet] ,[TipoCur] ,[Periodo] ,[DescPeriodo] ,[Curso] ,[DescCurso] ,[Serie]
      ,[DescSerie] ,[Turma] ,[nClasse] ,[CodStatus]  ,[CodiProf] ,[NomeProf] ,[ChaveTurma]  ,[OrdemCurso]
      ,[RAAlu]  ,[RaEst] ,[DtNascAlu]
  FROM [dbo].[qRelAvalAlunos] WHERE Curso = '1' and serie = 5 And Turma = 'B' order by nclasse</RecordSource>
      </DataSource>
    </DataSources>
    <ReportParameters>
      <ReportParameter>
        <Name>Parameter0</Name>
        <Values>
          <Item sys="string">1º Trimestre</Item>
          <Item sys="string">20/04/2018</Item>
        </Values>
        <Nullable>true</Nullable>
        <AllowBlank>true</AllowBlank>
        <MultiValue>true</MultiValue>
        <Hidden>true</Hidden>
        <AllowedValuesDefinition>
          <Values />
        </AllowedValuesDefinition>
      </ReportParameter>
      <ReportParameter>
        <Name>Titulo</Name>
        <Value sys="string">Relatório de Avaliação Individual</Value>
        <AllowBlank>true</AllowBlank>
        <Hidden>true</Hidden>
        <AllowedValuesDefinition>
          <Values />
        </AllowedValuesDefinition>
      </ReportParameter>
    </ReportParameters>
    <Groups>
      <Group>
        <Name>NomeAlu</Name>
        <GroupBy>CodiMatricula</GroupBy>
        <KeepTogether>KeepFirstDetail</KeepTogether>
        <OutlineLabel>
          <Expression>NomeAlu</Expression>
        </OutlineLabel>
      </Group>
    </Groups>
    <Sections>
      <Section>
        <Name>Detail</Name>
        <Background type="Solid">
          <Color>FFFFFFFF</Color>
        </Background>
        <SubSections>
          <SubSection>
            <Border>
              <Left>
                <Style>Solid</Style>
                <Width>15</Width>
              </Left>
              <Top>
                <Style>Solid</Style>
                <Width>15</Width>
              </Top>
              <Right>
