        <Content>
          <ParagraphText>
            <Font>
              <Name>Calibri</Name>
              <Size>9</Size>
              <Bold>true</Bold>
            </Font>
            <Text>
              <Value sys="string">Nota: </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Calibri</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Value sys="string">Excepcionalmente para o ano letivo de 2020 </Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Calibri</Name>
              <Size>10</Size>
              <Italic>true</Italic>
              <Underline>true</Underline>
            </Font>
            <Text>
              <Value sys="string">desconsiderar as cargas horárias acima descritas</Value>
            </Text>
          </ParagraphText>
          <ParagraphText>
            <Font>
              <Name>Calibri</Name>
              <Size>10</Size>
            </Font>
            <Text>
              <Value sys="string">, e considerar somente as especificações de cargas horárias constantes no campo observação no verso deste histórico.
</Value>
            </Text>
          </ParagraphText>
        </Content>
      </ParagraphField>
